{
  "name": "worldview-fm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy-events": "node -e \"const fs=require('fs');const src='../worldview-fm-agents/src/data/events.json';const dst='public/events-static.json';if(fs.existsSync(src)){fs.copyFileSync(src,dst);console.log('Copied events')}else{fs.writeFileSync(dst,'[]');console.log('Created empty events')}\"",
    "predeploy": "npm run copy-events && npm run build",
    "deploy": "npm run build"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "cesium": "^1.139.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "recharts": "^3.8.0",
    "resium": "^1.19.4",
    "satellite.js": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-cesium": "^1.2.23"
  }
}

# =============================================================================
# Fulcrum Memo — environment variables
# Copy to .env and fill in real values. .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Server-side (quant/scripts/*.py — local pipeline runs)
# -----------------------------------------------------------------------------
# FRED_API_KEY (no VITE_ prefix) is read by quant/scripts/fetch_fred_data.py
# during local pipeline runs. In CI the same value is supplied via the
# GitHub Actions secret of the same name; see .github/workflows/update-fulcrum-data.yml.
# Get a free key at https://fredaccount.stlouisfed.org/
FRED_API_KEY=your_fred_api_key_here

# -----------------------------------------------------------------------------
# Frontend (VITE_-prefixed, exposed to the browser via import.meta.env)
# -----------------------------------------------------------------------------
# VITE_FRED_API_KEY is used by src/data/fredApi.ts for live FRED fetches
# from the browser (current-value readouts in useLiveMarketData hook).
# Bulk historical data is bundled at build time by the Python pipeline,
# so this is optional — without it, fredApi.ts falls back to bundled values.
VITE_FRED_API_KEY=your_fred_api_key_here

# VITE_EIA_API_KEY is used by src/data/eiaApi.ts for live oil/gas prices.
# Get a free key at https://www.eia.gov/opendata/register.php
VITE_EIA_API_KEY=your_eia_api_key_here

# VITE_FMP_API_KEY — Financial Modeling Prep, used by Workshop steps
# (LiquidityStep, CapitalStructureStep, MemoGenerator). Required only if
# the Workshop section is in active use.
# Get a key at https://site.financialmodelingprep.com/developer/docs
VITE_FMP_API_KEY=your_financial_modeling_prep_api_key_here

# VITE_GEMINI_API_KEY — Google Gemini, used by src/services/geminiService.ts
# for AI-assisted memo features. Required only if those features are used.
# Get a key at https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
